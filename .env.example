# dicom_viewer Docker environment variables
# Copy to .env before running: cp .env.example .env

# --- Ports ---
HTTPS_PORT=443
HTTP_PORT=80

# --- Redis ---
REDIS_PASSWORD=changeme_redis_password

# --- PostgreSQL ---
POSTGRES_DB=dicom_viewer
POSTGRES_USER=dicom_viewer
POSTGRES_PASSWORD=changeme_postgres_password

# --- Server ---
LOG_LEVEL=info
MAX_SESSIONS=8
